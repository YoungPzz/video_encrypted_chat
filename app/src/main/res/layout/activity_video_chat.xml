<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/video_chat_background"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- 远程视频容器 - 动态添加视频视图 -->
    <FrameLayout
        android:id="@+id/remote_videos_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/control_panel"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- 远程视频视图将在这里动态添加 -->

    </FrameLayout>

    <!-- 本地视频小窗（画中画模式，用于2-3人时） -->
    <FrameLayout
        android:id="@+id/local_video_pip_container"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_margin="16dp"
        android:visibility="gone"
        android:elevation="10dp"
        android:background="#1A1A2E"
        android:clipChildren="false"
        android:clipToPadding="false">

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/local_video_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

        <TextView
            android:id="@+id/local_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="8dp"
            android:text="我"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:background="#80000000"
            android:padding="4dp"
            android:elevation="1dp" />

    </FrameLayout>

    <TextView
        android:id="@+id/status_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:background="@drawable/status_background"
        android:padding="8dp"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/timer_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/status_text_view"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:background="@drawable/status_background"
        android:padding="8dp"
        android:textColor="@android:color/white"
        android:textSize="14sp" />

    <!-- 控制面板 -->
    <LinearLayout
        android:id="@+id/control_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="32dp"
        android:background="@drawable/status_background"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/toggle_audio_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            android:background="@drawable/circle_button_background"
            android:contentDescription="@string/toggle_audio"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_mic_on" />

        <ImageButton
            android:id="@+id/hangup_button"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_margin="8dp"
            android:background="@drawable/circle_button_background_red"
            android:contentDescription="@string/hangup"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_hangup" />

        <ImageButton
            android:id="@+id/toggle_video_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            android:background="@drawable/circle_button_background"
            android:contentDescription="@string/toggle_video"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_video_on" />

    </LinearLayout>

</RelativeLayout>